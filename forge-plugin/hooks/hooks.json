{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh",
            "async": false
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/context-inject.sh",
            "async": false
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(ls ${CLAUDE_PLUGIN_ROOT}/sounds/stop/*.mp3 2>/dev/null | sort -R | head -1) && { afplay \"$f\" 2>/dev/null || paplay \"$f\" 2>/dev/null || true; }",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(ls ${CLAUDE_PLUGIN_ROOT}/sounds/permission/*.mp3 2>/dev/null | sort -R | head -1) && { afplay \"$f\" 2>/dev/null || paplay \"$f\" 2>/dev/null || true; }",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  }
}
